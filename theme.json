{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1200px"
    },
    "color": {
      "palette": [
        { "slug": "primary",          "color": "#0A1B33", "name": "Primary" },
        { "slug": "accent",           "color": "#0E7490", "name": "Accent" },
        { "slug": "accent-hover",     "color": "#155E75", "name": "Accent hover" },
        { "slug": "accent-tint",      "color": "#E1F1F6", "name": "Accent tint" },
        { "slug": "surface",          "color": "#FFFFFF", "name": "Surface" },
        { "slug": "surface-elevated", "color": "#F5F8FC", "name": "Surface elevated" },
        { "slug": "surface-sunken",   "color": "#EEF3F8", "name": "Surface sunken" },
        { "slug": "text",             "color": "#0B1B33", "name": "Text" },
        { "slug": "text-muted",       "color": "#5C6B82", "name": "Text muted" },
        { "slug": "border",           "color": "#E4EAF2", "name": "Border" },
        { "slug": "border-strong",    "color": "#CDD9EC", "name": "Border strong" }
      ],
      "defaultPalette": false,
      "custom": false,
      "customGradient": false
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "body",
          "name": "Body",
          "fontFamily": "\"Plus Jakarta Sans\", system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif",
          "fontFace": [
            { "fontFamily": "Plus Jakarta Sans", "fontWeight": "400", "fontStyle": "normal", "src": [ "file:./assets/fonts/plus-jakarta-sans-400.woff2" ] },
            { "fontFamily": "Plus Jakarta Sans", "fontWeight": "500", "fontStyle": "normal", "src": [ "file:./assets/fonts/plus-jakarta-sans-500.woff2" ] },
            { "fontFamily": "Plus Jakarta Sans", "fontWeight": "600", "fontStyle": "normal", "src": [ "file:./assets/fonts/plus-jakarta-sans-600.woff2" ] },
            { "fontFamily": "Plus Jakarta Sans", "fontWeight": "700", "fontStyle": "normal", "src": [ "file:./assets/fonts/plus-jakarta-sans-700.woff2" ] },
            { "fontFamily": "Plus Jakarta Sans", "fontWeight": "800", "fontStyle": "normal", "src": [ "file:./assets/fonts/plus-jakarta-sans-800.woff2" ] }
          ]
        },
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "\"Plus Jakarta Sans\", system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif",
          "fontFace": [
            { "fontFamily": "Plus Jakarta Sans", "fontWeight": "400", "fontStyle": "normal", "src": [ "file:./assets/fonts/plus-jakarta-sans-400.woff2" ] },
            { "fontFamily": "Plus Jakarta Sans", "fontWeight": "500", "fontStyle": "normal", "src": [ "file:./assets/fonts/plus-jakarta-sans-500.woff2" ] },
            { "fontFamily": "Plus Jakarta Sans", "fontWeight": "600", "fontStyle": "normal", "src": [ "file:./assets/fonts/plus-jakarta-sans-600.woff2" ] },
            { "fontFamily": "Plus Jakarta Sans", "fontWeight": "700", "fontStyle": "normal", "src": [ "file:./assets/fonts/plus-jakarta-sans-700.woff2" ] },
            { "fontFamily": "Plus Jakarta Sans", "fontWeight": "800", "fontStyle": "normal", "src": [ "file:./assets/fonts/plus-jakarta-sans-800.woff2" ] }
          ]
        },
        { "slug": "mono",    "name": "Mono",    "fontFamily": "ui-monospace, SFMono-Regular, Menlo, monospace" }
      ],
      "fontSizes": [
        { "slug": "xs",   "size": "clamp(0.75rem, 0.7rem + 0.2vw, 0.875rem)", "name": "XS" },
        { "slug": "sm",   "size": "clamp(0.875rem, 0.8rem + 0.3vw, 1rem)",     "name": "Small" },
        { "slug": "base", "size": "clamp(1rem, 0.9rem + 0.4vw, 1.125rem)",     "name": "Base" },
        { "slug": "lg",   "size": "clamp(1.125rem, 1rem + 0.6vw, 1.375rem)",   "name": "Large" },
        { "slug": "xl",   "size": "clamp(1.375rem, 1.2rem + 0.8vw, 1.75rem)",  "name": "XL" },
        { "slug": "2-xl", "size": "clamp(1.75rem, 1.5rem + 1.2vw, 2.25rem)",   "name": "2XL" },
        { "slug": "3-xl", "size": "clamp(1.9rem, 1.4rem + 2.4vw, 2.8rem)",     "name": "3XL" },
        { "slug": "4-xl", "size": "clamp(2.6rem, 1.9rem + 3.4vw, 4.5rem)",     "name": "4XL" }
      ],
      "fluid": true,
      "customFontSize": false,
      "lineHeight": true,
      "letterSpacing": true
    },
    "spacing": {
      "units": ["%", "px", "em", "rem", "vh", "vw"],
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 7,
        "mediumStep": 1.5,
        "unit": "rem"
      }
    },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        { "slug": "subtle", "name": "Subtle",  "shadow": "0 8px 24px -16px rgba(11,27,51,.25)" },
        { "slug": "medium", "name": "Medium",  "shadow": "0 24px 50px -28px rgba(11,27,51,.30)" },
        { "slug": "lifted", "name": "Lifted",  "shadow": "0 12px 24px -8px rgba(15, 23, 42, 0.12), 0 4px 8px -2px rgba(15, 23, 42, 0.06)" },
        { "slug": "focus",  "name": "Focus",   "shadow": "0 0 0 3px rgba(14,116,144,0.35)" }
      ]
    },
    "custom": {
      "color": {
        "text-on-dark": "#9DB6E6",
        "text-on-dark-soft": "#C9D6EC",
        "text-on-accent-muted": "#B9C8E6"
      }
    },
    "blocks": {
      "core/button": {
        "border": { "radius": true }
      }
    }
  },
  "styles": {
    "css": ".wp-site-blocks{display:flex;flex-direction:column;min-height:100vh;min-height:100dvh}.wp-site-blocks > main{flex:1 0 auto}section.starter-section{padding-block:clamp(3rem, 2rem + 5vw, 5.5rem);padding-inline:var(--wp--preset--spacing--30)}section.starter-section > :where(:not(.alignfull):not(.alignwide)){max-width:var(--wp--style--global--content-size, 720px);margin-inline:auto}.site-header{position:sticky;top:0;z-index:50;background:var(--wp--preset--color--surface)}.wp-block-navigation .wp-block-navigation-item.nav-cta a{background:var(--wp--preset--color--accent);color:var(--wp--preset--color--surface);border-radius:.5rem;padding:var(--wp--preset--spacing--20) var(--wp--preset--spacing--30);text-decoration:none}.wp-block-navigation .wp-block-navigation-item.nav-cta a:hover{background:var(--wp--preset--color--accent-hover);color:var(--wp--preset--color--surface)}.wp-block-navigation__responsive-container.is-menu-open{background:var(--wp--preset--color--surface)}.wp-block-navigation__responsive-container-open,.wp-block-navigation__responsive-container-close{color:var(--wp--preset--color--text)}.wp-block-navigation .current-menu-item > a,.wp-block-navigation a[aria-current='page']{color:var(--wp--preset--color--accent);text-decoration:underline;text-underline-offset:.35em}.wp-block-navigation a:focus-visible{outline:none;box-shadow:var(--wp--preset--shadow--focus);border-radius:.25rem}.wp-block-navigation__submenu-container{background:var(--wp--preset--color--surface);border:1px solid var(--wp--preset--color--border);border-radius:.5rem;box-shadow:var(--wp--preset--shadow--lifted);padding:var(--wp--preset--spacing--20)}.wp-block-navigation .wp-block-spacer{height:auto!important;min-height:0!important}",
    "color": {
      "background": "var(--wp--preset--color--surface)",
      "text": "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.65"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--40)",
      "padding": {
        "left":  "clamp(20px, 4vw, 40px)",
        "right": "clamp(20px, 4vw, 40px)"
      }
    },
    "elements": {
      "h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)", "fontSize": "var(--wp--preset--font-size--4-xl)", "lineHeight": "1.05", "letterSpacing": "-0.03em", "fontWeight": "800" } },
      "h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)", "fontSize": "var(--wp--preset--font-size--3-xl)", "lineHeight": "1.12", "letterSpacing": "-0.02em", "fontWeight": "800" } },
      "h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)", "fontSize": "var(--wp--preset--font-size--xl)",  "lineHeight": "1.3",  "letterSpacing": "-0.01em",  "fontWeight": "600" } },
      "h4": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)", "fontSize": "var(--wp--preset--font-size--lg)",  "lineHeight": "1.4",  "fontWeight": "600" } },
      "link": {
        "color":      { "text": "var(--wp--preset--color--accent)" },
        ":hover":     { "color": { "text": "var(--wp--preset--color--accent-hover)" } },
        "typography": { "textDecoration": "underline" }
      },
      "button": {
        "color":      { "text": "var(--wp--preset--color--surface)", "background": "var(--wp--preset--color--accent)" },
        "typography": { "fontWeight": "600" },
        "border":     { "radius": "0.5rem" },
        "spacing":    { "padding": { "top": "var(--wp--preset--spacing--20)", "right": "var(--wp--preset--spacing--30)", "bottom": "var(--wp--preset--spacing--20)", "left": "var(--wp--preset--spacing--30)" } },
        ":hover":     { "color": { "text": "var(--wp--preset--color--surface)", "background": "var(--wp--preset--color--accent-hover)" } },
        ":focus":     { "color": { "text": "var(--wp--preset--color--surface)", "background": "var(--wp--preset--color--accent-hover)" } }
      }
    },
    "blocks": {
      "core/navigation": {
        "typography": { "fontSize": "var(--wp--preset--font-size--sm)", "fontWeight": "500" },
        "elements": {
          "link": {
            "color": { "text": "var(--wp--preset--color--text)" },
            "typography": { "textDecoration": "none" },
            ":hover": { "color": { "text": "var(--wp--preset--color--accent)" } }
          }
        }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ],
  "customTemplates": [
    { "name": "front-page", "title": "Home", "postTypes": ["page"] }
  ]
}
