<?xml version="1.0" encoding="UTF-8"?>
<wpml-config>
	<gutenberg-blocks>
		<gutenberg-block type="pediment/contact-form" translate="1">
			<key name="successMessage"/>
		</gutenberg-block>

		<gutenberg-block type="pediment/cta" translate="1">
			<key name="title"/>
			<key name="body"/>
			<key name="primaryText"/>
			<key name="primaryUrl" type="link"/>
			<key name="secondaryText"/>
			<key name="secondaryUrl" type="link"/>
		</gutenberg-block>

		<gutenberg-block type="pediment/faq-item" translate="1">
			<key name="question"/>
			<key name="answer"/>
		</gutenberg-block>

		<gutenberg-block type="pediment/feature" translate="1">
			<key name="title"/>
			<key name="text"/>
			<key name="linkText"/>
			<key name="linkUrl" type="link"/>
		</gutenberg-block>

		<gutenberg-block type="pediment/hero" translate="1">
			<key name="headline"/>
			<key name="subheadline"/>
			<key name="ctaText"/>
			<key name="ctaUrl" type="link"/>
			<key name="secondaryText"/>
			<key name="secondaryUrl" type="link"/>
			<key name="eyebrow"/>
			<key name="ticks">
				<key name="*"/>
			</key>
			<key name="statValue"/>
			<key name="statText"/>
			<key name="metrics">
				<key name="*">
					<key name="value"/>
					<key name="label"/>
				</key>
			</key>
		</gutenberg-block>

		<gutenberg-block type="pediment/image-caption" translate="1">
			<key name="caption"/>
			<key name="altOverride"/>
		</gutenberg-block>

		<gutenberg-block type="pediment/logo-cloud" translate="1">
			<key name="caption"/>
		</gutenberg-block>

		<gutenberg-block type="pediment/media-text" translate="1">
			<key name="altOverride"/>
		</gutenberg-block>

		<gutenberg-block type="pediment/mega-menu" translate="1">
			<key name="label"/>
			<key name="columns">
				<key name="*">
					<key name="heading"/>
					<key name="links">
						<key name="*">
							<key name="label"/>
							<key name="description"/>
							<key name="url" type="link"/>
						</key>
					</key>
				</key>
			</key>
		</gutenberg-block>

		<gutenberg-block type="pediment/pull-quote" translate="1">
			<key name="quote"/>
			<key name="citation"/>
		</gutenberg-block>

		<gutenberg-block type="pediment/section-head" translate="1">
			<key name="eyebrow"/>
			<key name="headline"/>
			<key name="lead"/>
		</gutenberg-block>

		<gutenberg-block type="pediment/slider" translate="1">
			<key name="slides">
				<key name="*">
					<key name="altOverride"/>
					<key name="eyebrow"/>
					<key name="heading"/>
					<key name="body"/>
					<key name="buttonText"/>
					<key name="buttonUrl" type="link"/>
				</key>
			</key>
		</gutenberg-block>

		<gutenberg-block type="pediment/stat" translate="1">
			<key name="value"/>
			<key name="label"/>
			<key name="context"/>
		</gutenberg-block>

		<gutenberg-block type="pediment/step" translate="1">
			<key name="title"/>
			<key name="text"/>
		</gutenberg-block>

		<gutenberg-block type="pediment/testimonial" translate="1">
			<key name="quote"/>
			<key name="authorName"/>
			<key name="authorRole"/>
		</gutenberg-block>
	</gutenberg-blocks>
</wpml-config>
