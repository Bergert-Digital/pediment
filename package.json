{
  "name": "pediment",
  "version": "0.1.3",
  "private": true,
  "scripts": {
    "start": "WP_EXPERIMENTAL_MODULES=true wp-scripts start --webpack-src-dir=src/blocks --output-path=build/blocks",
    "build": "WP_EXPERIMENTAL_MODULES=true wp-scripts build --webpack-src-dir=src/blocks --output-path=build/blocks && wp-scripts build-blocks-manifest --input=build/blocks --output=build/blocks-manifest.php",
    "lint:js": "wp-scripts lint-js src/",
    "lint:blocks": "node tools/lint-blocks.mjs",
    "lint:colors": "node tools/lint-colors.mjs",
    "format": "wp-scripts format src/",
    "test:js": "wp-scripts test-unit-js",
    "e2e": "playwright test",
    "env:start": "wp-env start",
    "env:stop": "wp-env stop"
  },
  "devDependencies": {
    "@babel/runtime": "^7.29.2",
    "@playwright/test": "^1.45.0",
    "@wordpress/element": "^6.46.0",
    "@wordpress/env": "^10.0.0",
    "@wordpress/scripts": "^32.2.0",
    "typescript": "^5.4.0"
  }
}
